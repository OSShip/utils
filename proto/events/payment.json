{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "PaymentEvent",
  "type": "object",
  "required": ["event_id", "type", "timestamp", "payload", "schema_version"],
  "properties": {
    "event_id": { "type": "string" },
    "type": { "type": "string", "enum": ["payout.recorded", "checkout.completed"] },
    "timestamp": { "type": "string", "format": "date-time" },
    "schema_version": { "type": "string" },
    "payload": {
      "type": "object",
      "required": ["enrollment_id", "listing_id", "gross_cents", "mentor_payout_cents"],
      "properties": {
        "enrollment_id": { "type": "string" },
        "listing_id": { "type": "string" },
        "gross_cents": { "type": "integer" },
        "mentor_payout_cents": { "type": "integer" }
      }
    }
  }
}
